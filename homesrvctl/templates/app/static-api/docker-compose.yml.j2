services:
  site:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - ./html:/usr/share/nginx/html:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1/ >/dev/null || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      - traefik.enable=true
      - traefik.docker.network={{ docker_network }}
      - traefik.http.routers.{{ safe_name }}-site.rule={{ traefik_host_rule }}
      - traefik.http.routers.{{ safe_name }}-site.entrypoints=web
      - traefik.http.services.{{ safe_name }}-site.loadbalancer.server.port=80
    networks:
      - {{ docker_network }}

  api:
    build:
      context: .
      dockerfile: api/Dockerfile
    restart: unless-stopped
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:{{ ports.api }}/healthz >/dev/null || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      - traefik.enable=true
      - traefik.docker.network={{ docker_network }}
      - traefik.http.routers.{{ safe_name }}-api.rule=({{ traefik_host_rule }}) && PathPrefix(`/api`)
      - traefik.http.routers.{{ safe_name }}-api.entrypoints=web
      - traefik.http.routers.{{ safe_name }}-api.priority=100
      - traefik.http.services.{{ safe_name }}-api.loadbalancer.server.port={{ ports.api }}
    networks:
      - {{ docker_network }}

networks:
  {{ docker_network }}:
    external: true
