body {
  margin: 0;
  font-family: "Trebuchet MS", "Segoe UI", sans-serif;
  background: linear-gradient(180deg, #f7f4ea 0%, #ece5d8 100%);
  color: #14213d;
}

main {
  max-width: 56rem;
  margin: 0 auto;
  padding: 4rem 1.5rem 5rem;
}

.hero {
  margin-bottom: 2rem;
}

.eyebrow {
  margin: 0 0 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #7a5c1f;
}

h1 {
  margin: 0 0 1rem;
  font-size: clamp(2.4rem, 7vw, 4.5rem);
  line-height: 1;
}

.lede {
  max-width: 38rem;
  font-size: 1.15rem;
  line-height: 1.7;
}

.panel {
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(20, 33, 61, 0.12);
  border-radius: 1rem;
  padding: 1.5rem;
  box-shadow: 0 20px 40px rgba(20, 33, 61, 0.08);
}

pre {
  overflow-x: auto;
  padding: 1rem;
  border-radius: 0.75rem;
  background: #14213d;
  color: #f7f7f7;
}
