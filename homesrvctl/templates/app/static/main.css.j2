body {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  background: #f6f3ee;
  color: #1f2933;
}

main {
  max-width: 42rem;
  margin: 0 auto;
  padding: 5rem 1.5rem;
}

h1 {
  margin-bottom: 0.75rem;
  font-size: clamp(2.25rem, 6vw, 4rem);
  line-height: 1.05;
}

p {
  font-size: 1.1rem;
  line-height: 1.7;
}
